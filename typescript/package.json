{
  "name": "@sentroy-co/client-sdk",
  "version": "2.2.0",
  "description": "TypeScript SDK for the Sentroy platform — REST resources + React components.",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.js"
    },
    "./react": {
      "types": "./dist/react/index.d.ts",
      "import": "./dist/react/index.js",
      "require": "./dist/react/index.js"
    },
    "./types": {
      "types": "./dist/types.d.ts",
      "import": "./dist/types.js",
      "require": "./dist/types.js"
    }
  },
  "files": [
    "dist",
    "src"
  ],
  "scripts": {
    "build": "tsc",
    "prepublishOnly": "npm run build"
  },
  "keywords": [
    "sentroy",
    "email",
    "sdk",
    "api",
    "mail",
    "typescript",
    "react",
    "media-manager"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Sentroy-Co/client-sdk.git",
    "directory": "typescript"
  },
  "homepage": "https://github.com/Sentroy-Co/client-sdk#readme",
  "bugs": {
    "url": "https://github.com/Sentroy-Co/client-sdk/issues"
  },
  "license": "MIT",
  "engines": {
    "node": ">=18.0.0"
  },
  "peerDependencies": {
    "react": ">=18.0.0",
    "react-dom": ">=18.0.0"
  },
  "peerDependenciesMeta": {
    "react": {
      "optional": true
    },
    "react-dom": {
      "optional": true
    }
  },
  "devDependencies": {
    "@types/node": "^25.6.0",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "typescript": "^5.5.4"
  }
}
